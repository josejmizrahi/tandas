# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# local agent tooling
.claude-flow/
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase
supabase/.branches/
supabase/.temp/
test-results/
playwright-report/

# Superpowers brainstorm session files
.superpowers/

# Xcode
ios/build/
ios/DerivedData/
ios/**/xcuserdata/
ios/**/*.xcworkspace/xcuserdata/
ios/**/*.xcuserstate
*.xcscmblueprint
*.xccheckout

# Swift Package Manager
.swiftpm/
ios/.build/

# Apple secrets
*.p8
*.p12
*.mobileprovision
ios/AuthKey_*.p8

# Fastlane
ios/fastlane/report.xml
ios/fastlane/Preview.html
ios/fastlane/screenshots/
ios/fastlane/test_output/

# iOS / Xcode
# Tandas.xcodeproj is xcodegen-generated and not tracked, EXCEPT for
# Package.resolved — Xcode Cloud builds with -disableAutomaticPackageResolution
# and needs the resolved file at this exact path; pre-resolving in
# ci_post_clone.sh is unreliable (exit 74 / network failures), so we commit
# the lockfile directly.
ios/Tandas.xcodeproj/*
!ios/Tandas.xcodeproj/project.xcworkspace
ios/Tandas.xcodeproj/project.xcworkspace/*
!ios/Tandas.xcodeproj/project.xcworkspace/xcshareddata
ios/Tandas.xcodeproj/project.xcworkspace/xcshareddata/*
!ios/Tandas.xcodeproj/project.xcworkspace/xcshareddata/swiftpm
ios/Tandas.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/*
!ios/Tandas.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved
ios/.build/
ios/DerivedData/
ios/build/
ios/*.xcworkspace/
.DS_Store
*.xcuserstate
*.xcuserdatad/
ios/Tandas.local.xcconfig

# Codegen tooling — Deno lockfile is regenerated on demand
scripts/codegen/deno.lock

# SPM package build artifacts (post ios/Packages/ unignore — only ignore caches)
ios/Packages/**/.build/
ios/Packages/**/Package.resolved
